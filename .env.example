# Site variant: pike | grill
VITE_SITE=pike

# Google Analytics 4 measurement ID (optional — analytics disabled if unset)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# SEO landing pages (off in production by default)
# Enable locally: copy .env.pike.local.example → .env.pike.local
# VITE_ENABLE_SEO_PAGES=true
